{
  "start": "entry",
  "nodes": {
    "entry": {
      "flow": [
        {
          "goto": [
            { "if": "props.npc.met_player == 'true' && props.npc.trust_player > 0.55", "goto": "returning" },
            { "if": "func.npcMood() == 'frustrated'", "goto": "frustrated" },
            { "if": "func.npcMood() == 'desperate'", "goto": "desperate" },
            { "if": "func.npcMood() == 'tired'", "goto": "tired" },
            { "else": "default" }
          ]
        }
      ]
    },
    "returning": {
      "flow": [
        {
          "texts": [
            "Good to see you again.",
            "Hey, you're back. Anything I can help with?"
          ]
        }
      ]
    },
    "frustrated": {
      "flow": [
        {
          "texts": [
            "This market is impossible.",
            "Everyone's trying to squeeze me."
          ]
        }
      ]
    },
    "desperate": {
      "flow": [
        {
          "texts": [
            "I can't keep the shelves stocked. Money's too tight.",
            "Business has been rough. Really rough."
          ]
        }
      ]
    },
    "tired": {
      "flow": [
        {
          "texts": [
            "Long days lately.",
            "Need to close early today."
          ]
        }
      ]
    },
    "default": {
      "flow": [
        {
          "texts": [
            "Business is business.",
            "Things are moving, slowly.",
            "You buying or just looking?"
          ]
        }
      ]
    }
  }
}
