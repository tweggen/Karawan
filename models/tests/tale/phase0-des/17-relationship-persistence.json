{
  "name": "relationship-persistence-across-days",
  "description": "Verify trust values persist across day boundaries and are not reset",
  "phase": "phase-0",
  "category": "relationships",
  "priority": "high",
  "globalTimeout": 35,
  "preconditions": "2 NPCs with initial trust=0.5, encounter on day 1 at 14:00 (trust updated to 0.6)",
  "expectedOutcome": "Trust=0.6 after day 1, persists at day boundary, remains 0.6 on day 2",
  "steps": [
    {
      "expect": {
        "type": "npc_created"
      },
      "timeout": 5,
      "comment": "NPC 1 created"
    },
    {
      "expect": {
        "type": "npc_created"
      },
      "timeout": 5,
      "comment": "NPC 2 created"
    },
    {
      "sleep": 200,
      "comment": "Allow scheduling"
    },
    {
      "expect": {
        "type": "node_arrival"
      },
      "timeout": 15,
      "comment": "Day 1 activities"
    },
    {
      "sleep": 300,
      "comment": "Advance toward encounter time"
    },
    {
      "expect": {
        "type": "encounter"
      },
      "timeout": 10,
      "comment": "Encounter on day 1 (trust updated)"
    },
    {
      "expect": {
        "type": "relationship_changed"
      },
      "timeout": 10,
      "comment": "Trust increased to 0.6"
    },
    {
      "sleep": 1000,
      "comment": "Advance to day boundary"
    },
    {
      "expect": {
        "type": "day_summary"
      },
      "timeout": 20,
      "comment": "Day 1 boundary, relationship data persisted"
    },
    {
      "sleep": 500,
      "comment": "Advance into day 2"
    },
    {
      "expect": {
        "type": "node_arrival"
      },
      "timeout": 15,
      "comment": "Day 2 activities, trust value unchanged"
    },
    {
      "action": "quit",
      "result": "pass"
    }
  ]
}
