  "steps": [
    {
      "expect": {
        "type": "npc_created"
      },
      "timeout": 5,
      "comment": "NPC 1 created (positive personality)"
    },
    {
      "expect": {
        "type": "npc_created"
      },
      "timeout": 5,
      "comment": "NPC 2 created"
    },
    {
      "sleep": 200,
      "comment": "Allow scheduling"
    },
    {
      "expect": {
        "type": "node_arrival"
      },
      "timeout": 15,
      "comment": "Day 1 activities"
    },
    {
      "sleep": 500,
      "comment": "Advance through encounters and day boundaries"
    },
    {
      "expect": {
        "type": "encounter"
      },
      "timeout": 10,
      "comment": "First encounter"
    },
    {
      "expect": {
        "type": "relationship_changed"
      },
      "timeout": 10,
      "comment": "Trust increases"
    },
    {
      "sleep": 1500,
      "comment": "Advance through remaining days"
    },
    {
      "expect": {
        "type": "encounter"
      },
      "timeout": 10,
      "comment": "Subsequent encounters"
    },
    {
      "expect": {
        "type": "day_summary"
      },
      "timeout": 20,
      "comment": "Day boundary processing"
    },
    {
