{
  "name": "encounter-avoidance-different-locations",
  "description": "Verify NPCs at different locations do not trigger encounter",
  "phase": "phase-0",
  "category": "encounters",
  "priority": "high",
  "globalTimeout": 30,
  "preconditions": "2 NPCs scheduled at different locations (workplace and home) at same time",
  "expectedOutcome": "No encounter event fires, relationship unchanged",
  "steps": [
    {
      "expect": {
        "type": "npc_created"
      },
      "timeout": 5,
      "comment": "NPC 1 created (workplace)"
    },
    {
      "expect": {
        "type": "npc_created"
      },
      "timeout": 5,
      "comment": "NPC 2 created (home)"
    },
    {
      "sleep": 200,
      "comment": "Allow scheduling"
    },
    {
      "expect": {
        "type": "node_arrival"
      },
      "timeout": 15,
      "comment": "NPC 1 arrives at workplace"
    },
    {
      "expect": {
        "type": "node_arrival"
      },
      "timeout": 15,
      "comment": "NPC 2 arrives at home"
    },
    {
      "sleep": 300,
      "comment": "Wait for encounter window to pass"
    },
    {
      "action": "quit",
      "result": "pass",
      "comment": "No encounter event should have fired"
    }
  ]
}
