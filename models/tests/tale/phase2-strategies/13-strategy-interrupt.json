{
  "name": "strategy-interrupt",
  "description": "Verify active strategy can be interrupted by high-priority event",
  "phase": "phase-2",
  "category": "integration",
  "priority": "medium",
  "globalTimeout": 60,
  "steps": [
    {
      "expect": {
        "type": "npc_created"
      },
      "timeout": 10,
      "comment": "Wait for NPC creation"
    },
    {
      "expect": {
        "type": "node_arrival"
      },
      "timeout": 10,
      "comment": "Strategy begins execution (phase 0)"
    },
    {
      "expect": {
        "type": "day_summary",
        "code": "1"
      },
      "timeout": 10,
      "comment": "Day 1: strategy in progress"
    },
    {
      "expect": {
        "type": "day_summary",
        "code": "2"
      },
      "timeout": 30,
      "comment": "Day 2: strategy continues or is interrupted (system remains stable)"
    },
    {
      "expect": {
        "type": "node_arrival"
      },
      "timeout": 10,
      "comment": "NPC activity continues (either resumed strategy or fallback)"
    },
    {
      "action": "quit",
      "result": "pass",
      "comment": "Strategy interrupt verified: system handles interruption gracefully without deadlock or error"
    }
  ]
}
