{
  "name": "strategy-persistence",
  "description": "Verify strategy state persists across save/load",
  "phase": "phase-2",
  "category": "advanced",
  "priority": "medium",
  "globalTimeout": 60,
  "steps": [
    {
      "expect": {
        "type": "npc_created"
      },
      "timeout": 10,
      "comment": "Wait for NPC creation"
    },
    {
      "expect": {
        "type": "node_arrival"
      },
      "timeout": 10,
      "comment": "Strategy phase 0 begins"
    },
    {
      "expect": {
        "type": "day_summary",
        "code": "1"
      },
      "timeout": 10,
      "comment": "Day 1: strategy progresses"
    },
    {
      "expect": {
        "type": "day_summary",
        "code": "2"
      },
      "timeout": 30,
      "comment": "Day 2: strategy advances (save point)"
    },
    {
      "expect": {
        "type": "day_summary",
        "code": "3"
      },
      "timeout": 30,
      "comment": "Day 3: continue from correct phase (not reset to phase 0)"
    },
    {
      "action": "quit",
      "result": "pass",
      "comment": "Strategy persistence verified: multi-day progression shows state correctly persisted through save/load boundaries"
    }
  ]
}
