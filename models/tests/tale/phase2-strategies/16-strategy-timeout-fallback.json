{
  "name": "strategy-timeout-fallback",
  "description": "Verify timeout triggers fallback storylet if strategy stalls",
  "phase": "phase-2",
  "category": "advanced",
  "priority": "medium",
  "globalTimeout": 60,
  "steps": [
    {
      "expect": {
        "type": "npc_created"
      },
      "timeout": 10,
      "comment": "Wait for NPC creation"
    },
    {
      "expect": {
        "type": "node_arrival"
      },
      "timeout": 10,
      "comment": "Strategy begins"
    },
    {
      "expect": {
        "type": "day_summary",
        "code": "1"
      },
      "timeout": 10,
      "comment": "Day 1: strategy running"
    },
    {
      "expect": {
        "type": "day_summary",
        "code": "2"
      },
      "timeout": 30,
      "comment": "Day 2: strategy timeout may trigger fallback"
    },
    {
      "expect": {
        "type": "node_arrival"
      },
      "timeout": 10,
      "comment": "Fallback storylet (rest, wander, etc.) selected"
    },
    {
      "action": "quit",
      "result": "pass",
      "comment": "Strategy timeout fallback verified: system doesn't hang; fallback allows NPC to continue"
    }
  ]
}
