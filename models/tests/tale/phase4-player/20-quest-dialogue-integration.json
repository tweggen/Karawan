{
  "name": "quest-dialogue-integration",
  "description": "Verify quest triggered via NPC dialogue, not just encounters",
  "phase": "phase-4",
  "category": "story",
  "priority": "low",
  "globalTimeout": 60,
  "steps": [
    {"expect": {"type": "npc_created"}, "timeout": 10, "comment": "NPC created"},
    {"expect": {"type": "request_emitted"}, "timeout": 10, "comment": "Request emitted (dialogue-triggered)"},
    {"expect": {"type": "encounter"}, "timeout": 30, "comment": "Player encounters NPC"},
    {"expect": {"type": "day_summary", "code": "1"}, "timeout": 10, "comment": "Day 1: quest accepted via dialogue"},
    {"expect": {"type": "signal_emitted"}, "timeout": 60, "comment": "Signal emitted (quest progresses)"},
    {"expect": {"type": "day_summary", "code": "2"}, "timeout": 30, "comment": "Day 2: dialogue integration confirmed"},
    {"action": "quit", "result": "pass", "comment": "Quest dialogue integration verified: quests can be accepted through NPC conversation flow"}
  ]
}
