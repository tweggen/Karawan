    {"expect": {"type": "encounter"}, "timeout": 30, "comment": "Quest A triggered (low priority)"},
    {"expect": {"type": "day_summary", "code": "1"}, "timeout": 10, "comment": "Day 1: Quest A followed"},
    {"expect": {"type": "encounter"}, "timeout": 30, "comment": "High-priority quest B becomes available"},
    {"expect": {"type": "day_summary", "code": "2"}, "timeout": 30, "comment": "Day 2: priority interrupt occurs"},
    {"action": "quit", "result": "pass", "comment": "Quest priority verified: high-priority quest can interrupt lower-priority"}
