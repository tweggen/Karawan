{
  "name": "quest-failure-conditions",
  "description": "Verify quest can fail (timeout, dialogue choice, etc.)",
  "phase": "phase-4",
  "category": "feedback",
  "priority": "medium",
  "globalTimeout": 60,
  "steps": [
